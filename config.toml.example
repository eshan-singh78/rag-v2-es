[database]
host = "localhost"
grpc_port = 6334          # Qdrant gRPC port
rest_port = 6333          # Qdrant REST port (used by health check)
collection_name = "rag-documents"
dimension = 768           # nomic-embed-text output dim
metric = "cosine"         # cosine | dot | euclid

[embedding]
model = "nomic-embed-text"   # 768-dim, strong retrieval model

[llm]
model = "llama3.2:3b"

[retrieval]
vector_fetch_k = 30
bm25_top_k = 20
rerank_top_n = 6
# Minimum cross-encoder score to include a chunk (tune per corpus)
rerank_score_threshold = 0.15
# If the best chunk is below this, refuse to answer entirely
min_rerank_score = 0.20

[ingestion]
child_chunk_size = 512
child_chunk_overlap = 64
parent_chunk_size = 1536
parent_chunk_overlap = 128
batch_size = 64
max_retries = 3
data_path = "data"
ingest_workers = 4

[cache]
ttl_seconds = 3600
